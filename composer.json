{
    "name": "launchdarkly/server-sdk-otel",
    "description": "LaunchDarkly Server-Side SDK for PHP — OpenTelemetry integration",
    "keywords": [
        "launchdarkly",
        "launchdarkly php",
        "opentelemetry",
        "otel"
    ],
    "homepage": "https://github.com/launchdarkly/php-server-sdk-otel",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "LaunchDarkly <sdks@launchdarkly.com>",
            "homepage": "https://launchdarkly.com/"
        }
    ],
    "require": {
        "php": ">=8.1",
        "launchdarkly/server-sdk": "^6.7",
        "open-telemetry/api": "^1.0",
        "psr/log": "^1.0|^2.0|^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.80",
        "open-telemetry/sdk": "^1.0",
        "phpunit/phpunit": "^9",
        "vimeo/psalm": "^6.13"
    },
    "autoload": {
        "psr-4": {
            "LaunchDarkly\\": "src/LaunchDarkly/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaunchDarkly\\OpenTelemetry\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": false,
            "tbachert/spi": false
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "psalm": "vendor/bin/psalm --no-cache",
        "cs-check": "vendor/bin/php-cs-fixer fix --diff --dry-run --verbose --config=.php-cs-fixer.php",
        "cs-fix": "vendor/bin/php-cs-fixer fix --diff --verbose --config=.php-cs-fixer.php"
    }
}
